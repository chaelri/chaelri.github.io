{
  "manifest_version": 3,
  "name": "AnimeDownloader",
  "version": "1.0.0",
  "description": "One-click anime bulk downloader via AnimePahe. Discover on LiveChart, download everything automatically.",
  "permissions": ["tabs", "storage", "downloads", "tabGroups", "contextMenus"],
  "host_permissions": [
    "*://*.livechart.me/*",
    "*://*.animepahe.pw/*",
    "*://kwik.cx/*",
    "*://pahe.win/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "AnimeDownloader"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.animepahe.pw/play/*",
        "*://kwik.cx/*",
        "*://pahe.win/*"
      ],
      "js": ["content/guard.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": ["*://*.livechart.me/*"],
      "js": ["content/livechart.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.animepahe.pw/*"],
      "js": ["content/animepahe.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://kwik.cx/*"],
      "js": ["content/kwik.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://pahe.win/*"],
      "js": ["content/pahe.js"],
      "run_at": "document_idle"
    }
  ]
}
